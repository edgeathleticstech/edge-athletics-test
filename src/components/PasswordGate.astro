---
interface Props {
  password: string;
}

const { password } = Astro.props;

// Simple obfuscation — encode password so it's not plain text in source
// This is NOT cryptographic security — it's a casual gate for non-sensitive content
const encoded = Buffer.from(password).toString('base64');
---

<div class="password-gate" id="passwordGate">
  <div class="gate-card">
    <div class="gate-icon">🔒</div>
    <h2>Protected Content</h2>
    <p>This page is password-protected. Enter the password to view.</p>
    <div class="gate-form">
      <input
        type="password"
        id="gatePasswordInput"
        placeholder="Enter password"
        autocomplete="off"
      />
      <button type="button" id="gateSubmitBtn">View Page</button>
    </div>
    <p class="gate-error" id="gateError">Incorrect password. Please try again.</p>
  </div>
</div>

<div class="protected-content" id="protectedContent" style="display: none;">
  <slot />
</div>

<script define:vars={{ encoded }}>
  const gate = document.getElementById('passwordGate');
  const content = document.getElementById('protectedContent');
  const input = document.getElementById('gatePasswordInput');
  const btn = document.getElementById('gateSubmitBtn');
  const error = document.getElementById('gateError');

  function checkPassword() {
    const attempt = input.value;
    const decoded = atob(encoded);
    if (attempt === decoded) {
      gate.style.display = 'none';
      content.style.display = 'block';
      sessionStorage.setItem('ea_access_' + encoded, 'true');
    } else {
      error.style.display = 'block';
      input.value = '';
      input.focus();
    }
  }

  // Check if already authenticated this session
  if (sessionStorage.getItem('ea_access_' + encoded) === 'true') {
    gate.style.display = 'none';
    content.style.display = 'block';
  }

  btn.addEventListener('click', checkPassword);
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') checkPassword();
  });
</script>

<style>
  .password-gate {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    padding: 2rem 1.5rem;
  }

  .gate-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 3rem 2.5rem;
    max-width: 420px;
    width: 100%;
    text-align: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  .gate-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .gate-card h2 {
    font-size: 1.4rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .gate-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .gate-form {
    display: flex;
    gap: 0.5rem;
  }

  .gate-form input {
    flex: 1;
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-family);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .gate-form input:focus {
    border-color: var(--color-primary);
  }

  .gate-form button {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: 0.7rem 1.25rem;
    border-radius: 6px;
    font-family: var(--font-family);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .gate-form button:hover {
    background: var(--color-primary-light);
  }

  .gate-error {
    display: none;
    color: var(--color-accent) !important;
    font-size: 0.85rem !important;
    margin-top: 1rem !important;
    margin-bottom: 0 !important;
  }

  .protected-content {
    width: 100%;
  }

  @media (max-width: 480px) {
    .gate-form {
      flex-direction: column;
    }

    .gate-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
