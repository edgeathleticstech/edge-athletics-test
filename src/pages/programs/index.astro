---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const programs = (await getCollection('programs'))
  .filter((p) => p.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Programs">
  <section class="page-header">
    <div class="container">
      <h1>Programs</h1>
      <p>Edge Athletics offers a variety of basketball programs year-round for athletes of all ages and skill levels.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="programs-list">
        {programs.map((program) => (
          <a href={`/programs/${program.id}`} class="program-row">
            <div class="program-info">
              <span class="program-season">{program.data.season}</span>
              <h2>{program.data.title}</h2>
              <p>{program.data.description}</p>
              <div class="program-details">
                {program.data.ageRange && <span>Ages {program.data.ageRange}</span>}
                {program.data.tuition && <span>{program.data.tuition}</span>}
                {program.data.location && <span>{program.data.location}</span>}
              </div>
            </div>
            <span class="program-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: var(--color-primary);
    color: white;
    padding: 3rem 1.5rem;
  }

  .container { max-width: var(--max-width); margin: 0 auto; }

  .page-header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
  }

  .page-header p { color: rgba(255, 255, 255, 0.8); font-size: 1.1rem; }

  .section { padding: 2rem 1.5rem; }

  .programs-list { display: flex; flex-direction: column; gap: 1rem; }

  .program-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease;
  }

  .program-row:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    text-decoration: none;
  }

  .program-season {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .program-info h2 { font-size: 1.3rem; color: var(--color-primary); margin-bottom: 0.35rem; }
  .program-info p { color: var(--color-text-light); font-size: 0.9rem; margin-bottom: 0.5rem; }

  .program-details {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .program-arrow {
    font-size: 1.5rem;
    color: var(--color-primary);
    flex-shrink: 0;
    margin-left: 1rem;
  }

  @media (max-width: 768px) {
    .program-details { flex-direction: column; gap: 0.25rem; }
  }
</style>
