---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const announcements = (await getCollection('announcements'))
  .filter((a) => a.data.active)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const programs = (await getCollection('programs'))
  .filter((p) => p.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-inner">
      <h1>Edge Athletics</h1>
      <p class="hero-subtitle">Developing basketball players in the Hudson Valley since 1996</p>
      <p class="hero-tagline">AAU Sanctioned Program</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Announcements</h2>
      <div class="announcements-list">
        {announcements.length > 0 ? (
          announcements.map(async (announcement) => {
            const { Content } = await render(announcement);
            return (
              <article class:list={['announcement-card', { urgent: announcement.data.urgent }]}>
                <div class="announcement-header">
                  {announcement.data.urgent && <span class="urgent-badge">Urgent</span>}
                  <span class="announcement-date">
                    {new Date(announcement.data.date).toLocaleDateString('en-US', {
                      month: 'long',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                  </span>
                </div>
                <h3>{announcement.data.title}</h3>
                <div class="announcement-body">
                  <Content />
                </div>
              </article>
            );
          })
        ) : (
          <p class="empty-state">No current announcements.</p>
        )}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Our Programs</h2>
      <div class="programs-grid">
        {programs.map((program) => (
          <a href={`/programs/${program.id}`} class="program-card">
            <div class="program-card-content">
              <span class="program-season">{program.data.season}</span>
              <h3>{program.data.title}</h3>
              <p>{program.data.description}</p>
              {program.data.ageRange && (
                <span class="program-meta">Ages {program.data.ageRange}</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-primary);
    color: white;
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 0.35rem 1rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.75rem;
  }

  .section { padding: 3rem 1.5rem; }
  .section-alt { background: var(--color-bg-alt); }
  .container { max-width: var(--max-width); margin: 0 auto; }

  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .announcements-list { display: flex; flex-direction: column; gap: 1rem; }

  .announcement-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    border-left: 4px solid var(--color-primary);
  }

  .announcement-card.urgent {
    border-left-color: var(--color-urgent);
    background: #fef7f5;
  }

  .announcement-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .urgent-badge {
    background: var(--color-urgent);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .announcement-date { color: var(--color-text-light); font-size: 0.85rem; }

  .announcement-card h3 {
    font-size: 1.2rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .announcement-body { color: var(--color-text); font-size: 0.95rem; }
  .announcement-body :global(p) { margin-bottom: 0.5rem; }

  .empty-state { color: var(--color-text-light); font-style: italic; }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .program-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .program-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .program-card-content { padding: 1.5rem; }

  .program-season {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .program-card h3 { font-size: 1.2rem; color: var(--color-primary); margin-bottom: 0.5rem; }
  .program-card p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.5; margin-bottom: 0.75rem; }
  .program-meta { color: var(--color-text-light); font-size: 0.85rem; font-weight: 600; }

  @media (max-width: 768px) {
    .hero { padding: 3rem 1.5rem; }
    .hero h1 { font-size: 2rem; }
    .programs-grid { grid-template-columns: 1fr; }
  }
</style>
